# Copy this file to .env.local and replace every value with your own.
# The example values below are placeholders — the app builds with them,
# but real functionality requires real credentials.

# ── Supabase ───────────────────────────────────────────────
# Create a project at https://supabase.com and run supabase/migrations/*.sql
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic (Claude) ─────────────────────────────────────
# Used for AI post generation & correction. https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key

# ── LinkedIn OAuth (Posts API) ─────────────────────────────
# Create an app at https://www.linkedin.com/developers/apps
# Scopes: openid profile w_member_social
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/callback

# ── Access control ─────────────────────────────────────────
# Only users whose email ends with this domain may sign in (via Google OAuth
# configured in Supabase Auth). Include the leading "@".
ALLOWED_EMAIL_DOMAIN=@example.com
